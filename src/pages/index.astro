---
import Companion from "../components/Companion.astro";
import Connect from "../components/Connect.astro";
import Experience from "../components/Experience.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Marquee from "../components/Marquee.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Sinem Demiröz Gezici — Performance Marketing"
    description="Performance marketing manager driving growth for games played by millions. Currently crafting user acquisition and creative strategy at Rovio, the home of Angry Birds."
>
    <Header />
    <main>
        <Hero />
        <Marquee />
        <Experience />
        <Connect />
    </main>
    <Footer />
    <Companion />
</Layout>

<script>
    const revealed = document.querySelectorAll("[data-reveal]");
    const observer = new IntersectionObserver(
        (entries) => {
            for (const entry of entries) {
                if (entry.isIntersecting) {
                    entry.target.classList.add("is-visible");
                    observer.unobserve(entry.target);
                }
            }
        },
        { threshold: 0.15, rootMargin: "0px 0px -5% 0px" },
    );
    revealed.forEach((el) => observer.observe(el));
</script>
