<header
    class="fixed inset-x-0 top-0 z-40 flex items-center justify-between px-6 py-5 sm:px-10"
>
    <a
        href="#top"
        class="font-display text-lg tracking-tight"
        aria-label="Back to top"
    >
        S<span class="text-accent">.</span>DG
    </a>

    <div class="flex items-center gap-6">
        <p
            class="hidden items-baseline gap-2 text-[11px] tracking-[0.2em] uppercase text-ink-faint sm:flex"
        >
            Stockholm
            <span id="local-time" class="tabular-nums text-ink-soft"></span>
        </p>
        <a
            href="mailto:sinem@gezici.me"
            class="rounded-full border border-line px-4 py-1.5 text-[11px] tracking-[0.2em] uppercase transition-colors duration-300 hover:border-accent hover:text-accent"
        >
            Say hi
        </a>
    </div>
</header>

<script>
    const el = document.getElementById("local-time");
    const fmt = new Intl.DateTimeFormat("en-GB", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        timeZone: "Europe/Stockholm",
    });
    const tick = () => {
        if (el) el.textContent = fmt.format(new Date());
    };
    tick();
    setInterval(tick, 1000);
</script>
